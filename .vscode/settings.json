{
  // Surface tailwindcss/* ESLint findings in the editor and fix on save
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.useFlatConfig": true,

  // Tailwind IntelliSense: autocomplete + unknown-class highlighting inside
  // the classname helpers used in this codebase (cn, clsx, cva, twMerge)
  "tailwindCSS.experimental.classRegex": [
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
    ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
    ["classnames\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
    ["twMerge\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"]
  ],
  "tailwindCSS.validate": true,

  // @tailwind / @apply are valid here; stop the built-in CSS linter
  // from flagging them
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore"
}
